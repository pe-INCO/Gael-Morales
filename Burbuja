#include <stdio.h>

int main() {
    int arreglo[] = {5, 2, 9, 1, 6};
    int n = 5;
    int i, j, temp;

    // Ordenamiento burbuja
    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - 1 - i; j++) {
            if (arreglo[j] > arreglo[j + 1]) {
                temp = arreglo[j];
                arreglo[j] = arreglo[j + 1];
                arreglo[j + 1] = temp;
            }
        }
    }

    // Mostrar resultado
    printf("Arreglo ordenado:\n");
    for (i = 0; i < n; i++) {
        printf("%d ", arreglo[i]);
    }

    return 0;
}
