#include <stdio.h>
#include <stdlib.h>

int main()
{
    struct registro {
        char nombre[50];
        float calificacion[4];
    };

    struct registro matriz[3];

    int opcion;
    int i, j;

    do {
        printf("\033[H\033[J"); // limpiar pantalla (ANSI)

        printf("=== Programa promedios ===\n\n");

        printf("1- Ingresar notas\n");
        printf("2- Mostrar la matriz completa\n");
        printf("3- Promedio de cada estudiante\n");
        printf("4- Promedio de cada materia\n");
        printf("5- Nota mas alta y su posicion\n");
        printf("6- Salir\n\n");

        printf("Ingresa una opcion: ");
        scanf("%d", &opcion);

        getchar(); // limpiar buffer

        switch(opcion)
        {
            case 1:
                printf("\033[H\033[J");

                for(i = 0; i < 3; i++) {
                    printf("\nEstudiante %d\n", i + 1);

                    printf("Nombre: ");
                    scanf("%s", matriz[i].nombre);

                    for(j = 0; j < 4; j++) {
                        printf("Calificacion %d: ", j + 1);
                        scanf("%f", &matriz[i].calificacion[j]);
                    }
                }

                printf("\nDatos ingresados correctamente...\n");
                printf("Presiona Enter para continuar...");
                getchar();
                break;

            case 2:
                printf("\033[H\033[J");

                printf("\nDatos guardados:\n");
                for(i = 0; i < 3; i++) {
                    printf("%s: ", matriz[i].nombre);

                    for(j = 0; j < 4; j++) {
                        printf("%.2f ", matriz[i].calificacion[j]);
                    }
                    printf("\n");
                }

                printf("\nPresiona Enter para continuar...");
                getchar();
                break;

            case 3:
                printf("\033[H\033[J");

                for(i = 0; i < 3; i++) {
                    float suma = 0;

                    for(j = 0; j < 4; j++) {
                        suma += matriz[i].calificacion[j];
                    }

                    float promedio = suma / 4;

                    printf("El promedio de %s es: %.2f\n", matriz[i].nombre, promedio);
                }

                printf("\nPresiona Enter para continuar...");
                getchar();
                break;

            case 4:
                printf("\033[H\033[J");

                for(j = 0; j < 4; j++) {
                    float suma = 0;

                    for(i = 0; i < 3; i++) {
                        suma += matriz[i].calificacion[j];
                    }

                    float promedio = suma / 3;

                    printf("Promedio de la materia %d: %.2f\n", j + 1, promedio);
                }

                printf("\nPresiona Enter para continuar...");
                getchar();
                break;

            case 5:
            {
                printf("\033[H\033[J");

                float mayor = matriz[0].calificacion[0];
                int est = 0, mat = 0;

                for(i = 0; i < 3; i++) {
                    for(j = 0; j < 4; j++) {
                        if(matriz[i].calificacion[j] > mayor) {
                            mayor = matriz[i].calificacion[j];
                            est = i;
                            mat = j;
                        }
                    }
                }

                printf("La nota mas alta es: %.2f\n", mayor);
                printf("Estudiante: %s\n", matriz[est].nombre);
                printf("Posicion -> Estudiante %d, Materia %d\n", est + 1, mat + 1);

                printf("\nPresiona Enter para continuar...");
                getchar();
                break;
            }

            case 6:
                printf("Saliendo...\n");
                break;
        }

    } while(opcion != 6);

    return 0;
}
