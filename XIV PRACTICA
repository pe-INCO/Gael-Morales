#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main()
{
    int arreglo[10] = {0};
    int opcion = 0;
    int valor, pos;
    int n = 5; // cantidad de elementos actuales

    srand(time(NULL));

    // Inicializar los primeros 5 elementos aleatorios
    for (int i = 0; i < n; i++) {
        arreglo[i] = rand() % 100 + 1;
    }

    printf("==MENU==\n");
    printf("1. Inicializar arreglo con valores aleatorios\n");
    printf("2. Mostrar arreglo actual\n");
    printf("3. Agregar elemento al final\n");
    printf("4. Insertar elemento en posición específica\n");
    printf("5. Eliminar elemento por posición\n");
    printf("6. Buscar elemento\n");
    printf("7. Ordenar ascendente/descendente\n");
    printf("8. Salir\n");

    while(opcion != 8){
        printf("\nIngresa una opcion: ");
        scanf("%d", &opcion);

        switch(opcion)
        {
            case 1: 
                n = 5;
                for (int i = 0; i < n; i++) {
                    arreglo[i] = rand() % 100 + 1;
                }
                printf("Se inicializaron 5 valores aleatorios.\n");
                break;

            case 2:
                printf("Contenido del arreglo:\n");
                for (int i = 0; i < 10; i++) {
                    printf("arreglo[%d] = %d\n", i, arreglo[i]);
                }
                break;

            case 3:
                if (n < 10) {
                    printf("Ingresa el valor que quieras agregar: ");
                    scanf("%d", &valor);
                    arreglo[n] = valor;
                    n++;
                    printf("Valor agregado al final en la posición %d\n", n-1);
                } else {
                    printf("El arreglo está lleno, no se puede agregar más.\n");
                }
                break;

            case 4:
                printf("Ingresa la posicion (0-9) donde quieres insertar el elemento: ");
                scanf("%d", &pos);

                if(pos >= 0 && pos < 10) {
                    printf("Ingresa el valor que quieres agregar en esa posicion: ");
                    scanf("%d", &valor);
                    arreglo[pos] = valor;

                    // Ajustar n si agregamos más allá del último elemento actual
                    if(pos >= n) n = pos + 1;

                    printf("Valor agregado/sustituido en la posición %d\n", pos);
                } else {
                    printf("Posicion invalida.\n");
                }
                break;

            case 5:
                printf("Ingresa la posicion (0-9) que quieres eliminar: ");
                scanf("%d", &pos);

                if(pos >= 0 && pos < n) {
                    for(int i = pos; i < n-1; i++) {
                        arreglo[i] = arreglo[i+1];
                    }
                    arreglo[n-1] = 0;
                    n--;
                    printf("Elemento en la posición %d eliminado.\n", pos);
                } else {
                    printf("Posicion invalida.\n");
                }
                break;

            case 6:
                printf("Ingresa el valor a buscar: ");
                scanf("%d", &valor);
                int encontrado = 0;
                for(int i = 0; i < n; i++){
                    if(arreglo[i] == valor){
                        printf("Valor encontrado en la posición %d\n", i);
                        encontrado = 1;
                        break;
                    }
                }
                if(!encontrado) printf("Valor no encontrado.\n");
                break;

            case 7:
                printf("Ordenar ascendente (1) o descendente (2)? ");
                int modo;
                scanf("%d", &modo);
                for(int i = 0; i < n-1; i++){
                    for(int j = i+1; j < n; j++){
                        if((modo==1 && arreglo[i]>arreglo[j]) || (modo==2 && arreglo[i]<arreglo[j])){
                            int temp = arreglo[i];
                            arreglo[i] = arreglo[j];
                            arreglo[j] = temp;
                        }
                    }
                }
                printf("Arreglo ordenado.\n");
                break;

            case 8:
                printf("Saliendo...\n");
                break;

            default:
                printf("Opcion no valida\n");
                break;
        }
    }

    return 0;
}
