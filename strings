#include <stdio.h>

int main() {
    
    char cadena[99];
    int opcion;
    int i;

    do {
        printf("\n////// MENU //////\n");
        printf("Opcion 1: Ingresar frase\n");
        printf("Opcion 2: Longitud\n");
        printf("Opcion 3: Primeros 3 caracteres\n");
        printf("Opcion 8: Salir\n");

        printf("Ingresa una opcion: ");
        scanf("%d", &opcion);

        switch (opcion) {

            case 1:
                printf("Ingresa una frase: ");
                scanf("%s", cadena);
                break;

            case 2:
                i = 0;
                while (cadena[i] != '\0') {
                    i++;
                }
                printf("La longitud es: %d\n", i);
                break;

            case 3:
                printf("Los tres primeros caracteres son: %c, %c, %c\n",
                       cadena[0], cadena[1], cadena[2]);
                break;

            case 8:
                printf("Saliendo del programa...\n");
                break;

            default:
                printf("Opcion no valida\n");
        }

    } while (opcion != 8);

    return 0;
}
