#include <stdio.h>

int main() {
    char frase[100];

    printf("Ingresa una palabra: ");
    scanf("%s", frase);  // lee solo una palabra (hasta espacio)

    // Longitud
    int i = 0;
    while (frase[i] != '\0') {
        i++;
    }
    printf("La longitud de la palabra es: %d\n", i);

    // Primeros 3 caracteres
    printf("Los tres primeros caracteres son: ");
    for (int j = 0; j < 3 && frase[j] != '\0'; j++) {
        printf("%c", frase[j]);
    }
    printf("\n");

    // Mayúsculas (manual)
    printf("En mayúsculas: ");
    for (int j = 0; frase[j] != '\0'; j++) {
        if (frase[j] >= 'a' && frase[j] <= 'z') {
            printf("%c", frase[j] - 32);
        } else {
            printf("%c", frase[j]);
        }
    }
    printf("\n");

    // Minúsculas (manual)
    printf("En minúsculas: ");
    for (int j = 0; frase[j] != '\0'; j++) {
        if (frase[j] >= 'A' && frase[j] <= 'Z') {
            printf("%c", frase[j] + 32);
        } else {
            printf("%c", frase[j]);
        }
    }
    printf("\n");

    // Reemplazar vocales por @
    printf("Reemplazando vocales por @: ");
    for (int j = 0; frase[j] != '\0'; j++) {
        char c = frase[j];
        if (c=='a'||c=='e'||c=='i'||c=='o'||c=='u'||
            c=='A'||c=='E'||c=='I'||c=='O'||c=='U') {
            printf("@");
        } else {
            printf("%c", c);
        }
    }

    return 0;
}
